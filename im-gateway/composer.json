{
    "name": "b8im/im-gateway",
    "description": "b8im IM 通信层 - GatewayWorker 对外 WebSocket 接入（readme §6.2）。独立工程，可单独打 Docker、水平扩容。",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "workerman/gateway-worker": "^4.0",
        "vlucas/phpdotenv": "^5.6",
        "b8im/im-shared": "*"
    },
    "repositories": [
        { "type": "path", "url": "../../b8im-im-shared" }
    ],
    "autoload": {
        "psr-4": {
            "B8im\\ImGateway\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
