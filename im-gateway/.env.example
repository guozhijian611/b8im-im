# ---- im-gateway / GatewayWorker ----

# 对外 WebSocket 监听地址（App / Web 连这里）
GATEWAY_LISTEN = websocket://0.0.0.0:8787

# Gateway 进程数（建议 = CPU 核数）
GATEWAY_PROCESS_COUNT = 4

# 本机对内通信 IP（多机部署必须填内网可达 IP，单机用 127.0.0.1）
GATEWAY_LAN_IP = 127.0.0.1
GATEWAY_START_PORT = 2900

# RegisterWorker 地址（im-register），集群所有节点共用同一个
REGISTER_ADDRESS = 127.0.0.1:1238

# 内部通信密钥，必须与 im-register / im-business 一致
SECRET_KEY = please-change-me-to-a-strong-random-key

# 心跳超时秒数
PING_INTERVAL = 55
