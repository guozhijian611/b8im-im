# ---- im-business / BusinessWorker ----

# Business 进程数（可横向扩展）
BUSINESS_PROCESS_COUNT = 4

# RegisterWorker 地址（im-register），与 im-gateway 用同一个
REGISTER_ADDRESS = 127.0.0.1:1238

# 内部通信密钥，必须与 im-register / im-gateway 一致
SECRET_KEY = please-change-me-to-a-strong-random-key

# —— 业务依赖（后续接入时启用）——
# 数据库
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = nb8im
DB_USER = root
DB_PASSWORD = root
DB_CHARSET = utf8mb4

# Redis（在线状态/连接映射/限流，key 带租户前缀）
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD =
REDIS_DB = 0

# RabbitMQ（消息后处理：推送/审计/风控/统计）
RABBITMQ_HOST = 127.0.0.1
RABBITMQ_PORT = 5672
RABBITMQ_USER = guest
RABBITMQ_PASSWORD = guest
RABBITMQ_VHOST = /
RABBITMQ_EXCHANGE = im.message
MQ_OUTBOX_ENABLED = 1
MQ_OUTBOX_PROCESS_COUNT = 1
MQ_OUTBOX_BATCH_SIZE = 50
MQ_OUTBOX_INTERVAL_MS = 1000
MQ_OUTBOX_MAX_RETRY = 10
MQ_OUTBOX_RETRY_DELAY_SECONDS = 30
MQ_OUTBOX_LOCK_TTL_SECONDS = 60

# IM token 签名密钥（与 webman 控制面一致，用于校验客户端 token）
IM_TOKEN_SECRET = please-change-me

# 本地联调可设为 1 以允许 dev.<payload> 形式的未签名 token，生产环境必须保持 0
IM_TOKEN_ALLOW_INSECURE = 0

# 连接状态 Redis TTL（秒）
IM_CONNECTION_TTL = 604800

# 消息可撤回时间窗口（秒），0 表示不限制
IM_RECALL_WINDOW_SECONDS = 120

# 消息可编辑时间窗口（秒），0 表示不限制；未配置时沿用撤回时间
IM_EDIT_WINDOW_SECONDS = 120

# 单次离线/历史同步最大条数
IM_SYNC_MAX_LIMIT = 100

# 消息分片哈希桶数量；新部署周期可提高，已落表的数据不自动重分片
IM_MESSAGE_SHARD_BUCKETS = 64
