# ---- im-business / BusinessWorker ----

# Business 进程数（可横向扩展）
BUSINESS_PROCESS_COUNT = 4

# RegisterWorker 地址（im-register），与 im-gateway 用同一个
REGISTER_ADDRESS = 127.0.0.1:1238

# 内部通信密钥，必须与 im-register / im-gateway 一致
SECRET_KEY = please-change-me-to-a-strong-random-key

# IM 时间、分片月份与迁移统一时区。
IM_TIMEZONE = Asia/Shanghai

# —— 业务依赖（后续接入时启用）——
# 数据库
DB_HOST = 127.0.0.1
DB_PORT = 3306
DB_NAME = nb8im
DB_USER = root
DB_PASSWORD = root
DB_CHARSET = utf8mb4

# Redis（在线状态/连接映射/限流，key 带租户前缀）
REDIS_HOST = 127.0.0.1
REDIS_PORT = 6379
REDIS_PASSWORD =
REDIS_DB = 0

# RabbitMQ（消息后处理：推送/审计/风控/统计）
RABBITMQ_HOST = 127.0.0.1
RABBITMQ_PORT = 5672
RABBITMQ_USER = guest
RABBITMQ_PASSWORD = guest
RABBITMQ_VHOST = /
RABBITMQ_EXCHANGE = im.message
MQ_OUTBOX_ENABLED = 1
MQ_OUTBOX_PROCESS_COUNT = 1
MQ_OUTBOX_BATCH_SIZE = 50
MQ_OUTBOX_INTERVAL_MS = 1000
MQ_OUTBOX_MAX_RETRY = 10
MQ_OUTBOX_RETRY_DELAY_SECONDS = 30
MQ_OUTBOX_LOCK_TTL_SECONDS = 60

# RabbitMQ -> Gateway 可靠实时补投。坏载荷直接进 DLQ，网关异常有界重试后进 DLQ。
MQ_REALTIME_ENABLED = 1
MQ_REALTIME_PROCESS_COUNT = 1
MQ_REALTIME_PREFETCH = 50
MQ_REALTIME_POLL_INTERVAL_MS = 50
MQ_REALTIME_MAX_RETRY = 5
MQ_REALTIME_RETRY_TTL_SECONDS = 86400

# OpenTelemetry Trace（只使用 OTLP/HTTP protobuf）。采集端故障不得阻断 IM 业务。
OTEL_TRACES_ENABLED = false
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT = http://otel-collector:4318/v1/traces
OTEL_EXPORTER_OTLP_TRACES_TIMEOUT = 200
OTEL_BSP_SCHEDULE_DELAY_MS = 1000
OTEL_BSP_MAX_QUEUE_SIZE = 2048
OTEL_BSP_MAX_EXPORT_BATCH_SIZE = 256
OTEL_SERVICE_VERSION = dev
OTEL_DEPLOYMENT_ENVIRONMENT = local

# IM JWT 信任域。密钥至少 32 字节，issuer 使用稳定 deployment_id。
IM_TOKEN_SECRET = please-change-me-to-at-least-32-bytes
IM_TOKEN_TRUSTED_ISSUERS = b8im-local
IM_TOKEN_AUDIENCE = im
IM_TOKEN_CLOCK_SKEW_SECONDS = 30

# 连接状态 Redis TTL（秒）
IM_CONNECTION_TTL = 604800

# 单次离线/历史同步最大条数
IM_SYNC_MAX_LIMIT = 100

# 消息分片哈希桶数量；新部署周期可提高，已落表的数据不自动重分片
IM_MESSAGE_SHARD_BUCKETS = 64

# 模块授权共享缓存最大 TTL；实际 TTL 不得超过 license expire_at。
IM_MODULE_LICENSE_CACHE_TTL_SECONDS = 60

# 已鉴权连接重验机构/用户/设备/凭证会话的最大正缓存 TTL。
IM_AUTH_REVALIDATE_TTL_SECONDS = 3
