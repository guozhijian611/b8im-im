{
    "name": "b8im/im-register",
    "description": "b8im IM 通信层 - RegisterWorker 服务注册发现（readme §4.3 集群）。独立工程，可单独打 Docker。",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "workerman/gateway-worker": "^4.0",
        "vlucas/phpdotenv": "^5.6",
        "b8im/im-shared": "^1.0"
    },
    "repositories": [
        { "type": "path", "url": "../../b8im-im-shared" }
    ],
    "autoload": {
        "psr-4": {
            "B8im\\ImRegister\\": "src/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
